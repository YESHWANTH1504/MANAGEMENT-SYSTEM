# IMMS Backend Environment Configuration

# Gemini API Key (get yours from https://aistudio.google.com/)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Custom database URL (defaults to SQLite: sqlite:///./imms.db)
# DATABASE_URL=sqlite:///./imms.db

# Optional: Custom office coordinates for geofence (MCC MRF Innovation Park Chennai)
# OFFICE_LATITUDE=12.9213
# OFFICE_LONGITUDE=80.1220
# GEOFENCE_RADIUS_METERS=100.0

# Optional: SMTP email configuration settings (for actual password recovery link delivery)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_TLS=True
# SMTP_SSL=False
# SMTP_USER=your_smtp_username@gmail.com
# SMTP_PASSWORD=your_smtp_app_password
# EMAILS_FROM_EMAIL=your_smtp_username@gmail.com
# EMAILS_FROM_NAME="MCC ADMIN"
